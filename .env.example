# Example .env for savvy-uploader. Copy to .env and fill in.

# Required: SavvyAviation credentials and the aircraft you upload for.
SAVVY_EMAIL=you@example.com
SAVVY_PASSWORD=yourpassword
SAVVY_AIRCRAFT_ID=12345

# Required: directory holding engine-monitor CSVs.
# Files arrive here and stay forever; savvy-uploader is read-only on each
# CSV after upload, so concurrent readers are safe.
CSV_DIR=/path/to/engine/csv/files

# Optional. Override the browser user agent (defaults to Chrome 131 on Linux).
# USER_AGENT=

# Optional. If set, savvy writes a JSON-line summary of each upload run to
# this directory (file: savvy-YYYY-MM-DD.jsonl) instead of sending an email.
# Useful when an external process aggregates upload outcomes from multiple
# sources. Leave unset to keep the per-batch email behaviour.
# SUMMARY_DIR=

# Optional. Seconds to wait between the upload phase and the authoritative
# GraphQL flight-count query. Savvy parses uploaded CSVs asynchronously
# in multiple phases — flight attribution can land seconds-to-minutes
# after the upload page first reports "Success". The settle delay gives
# Phase 3 a chance to complete before we read the count.
# GRAPHQL_SETTLE_SECONDS=60

# Managed by the script — do not edit by hand.
# LAST_UPLOADED=
